class Solution {
    public int[] sortedSquares(int[] nums) {
        int i = 0;
        int j = nums.length-1;
        int k = j;
        int[] sortedSquares = new int[nums.length];
        while(i<=j){
            if(Math.abs(nums[i])>Math.abs(nums[j]))
                sortedSquares[k] = nums[i]*nums[i++];
            else{
                sortedSquares[k] = nums[j]*nums[j--];
            }
            k--;
        } 
        return sortedSquares;
    }
}
