class Solution {
    public int earliestTime(int[][] tasks) {
        int minTime = 0;
        int min = Integer.MAX_VALUE;
        for(int i=0;i<tasks.length;i++){
            minTime = tasks[i][0]+tasks[i][1];
            if(minTime<min)
                min = minTime;
        }
        return min;
    }
}
