class Solution {
    public int minimumBoxes(int[] apple, int[] capacity) {
        Arrays.sort(capacity);
        int total=0,box=0;
        for(int apples:apple)
            total += apples;
        for(int i=capacity.length-1;i>=0;i--){
            total-=capacity[i];
            box++;
            if(total<=0)
                return box;
        }
        return box;
    }
}
